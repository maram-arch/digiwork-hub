<?php

require_once __DIR__ . '/../../config/config.php';
require_once __DIR__ . '/../../controller/CommentaireController.php';

if ($_SERVER['REQUEST_METHOD'] !== 'POST') {
    header('Location: listCommentaires.php');
    exit;
}

$id_commentaire = (int)($_POST['id_commentaire'] ?? 0);
$contenu        = trim($_POST['contenu'] ?? '');

// Validation : commentaire obligatoire, minimum 2 caractères
if ($id_commentaire && strlen($contenu) >= 2) {
    // Nettoyage anti-XSS
    $contenu = htmlspecialchars($contenu, ENT_QUOTES, 'UTF-8');
    
    $controller = new CommentaireController();
    $ok = $controller->updateCommentaire($id_commentaire, $contenu);
    
    if ($ok) {
        header("Location: listCommentaires.php?status=success&msg=" . urlencode("Commentaire mis à jour avec succès."));
    } else {
        header("Location: listCommentaires.php?status=error&msg=" . urlencode("Erreur lors de la mise à jour du commentaire."));
    }
} else {
    $msg = $id_commentaire ? "Le commentaire doit contenir au moins 2 caractères." : "ID de commentaire invalide.";
    header("Location: listCommentaires.php?status=error&msg=" . urlencode($msg));
}
exit;
?>